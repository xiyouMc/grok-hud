{
  "name": "grok-hud",
  "version": "0.1.5",
  "description": "Real-time statusline HUD for Grok (xAI CLI) — context, git, tools, and credit usage (inspired by claude-hud)",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "grok-hud": "bin/grok-hud.js"
  },
  "files": [
    "dist/",
    "bin/",
    "commands/",
    "skills/",
    "plugin.json",
    ".grok-plugin/",
    "config.example.json",
    "README.md",
    "LICENSE",
    "grok-hud-preview.png"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "watch": "node dist/index.js --watch",
    "test:once": "node dist/index.js --once",
    "prepare": "tsc",
    "prepublishOnly": "npm run build",
    "plugin:validate": "grok plugin validate ."
  },
  "keywords": [
    "grok",
    "xai",
    "statusline",
    "hud",
    "cli",
    "plugin",
    "telemetry"
  ],
  "author": "xiyoumc",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xiyouMc/grok-hud.git"
  },
  "bugs": {
    "url": "https://github.com/xiyouMc/grok-hud/issues"
  },
  "homepage": "https://github.com/xiyouMc/grok-hud#readme",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "typescript": "^5.8.0"
  }
}
